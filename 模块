模块名：Builder
职责：收集子任务结果，拼装统一JSON

输入：
    {
        "task_id": "uuid-xxxx",
        "final_status": "SUCCESS",
        "results": [
            {"type": "image", "url": "/data/outputs/img_001.png"},
            {"type": "text", "content": "这是一张未来城市的图片..."}
        ],
        "call_chain": [
            {"model_name": "model-x", "capability": "image-generation", "status": "SUCCESS", "attempted_at": "..."},
            {"model_name": "model-A", "capability": "text-generation", "status": "SUCCESS", "attempted_at": "..."}
        ]
    }
输出：
    - 成功（final_status为FALLBACK_SUCCESS）：
    {
        "frontend_response":{
            "task_id": "uuid-xxxx",
            "task_status": "SUCCESS",
            "system_status": "READY",
            "data": {
                "results": [
                    {"type": "image", "url": "/data/outputs/img_001.png"},
                    {"type": "text", "content": "这是一张未来城市的图片..."}
                ]
            }
        },
        "log_record":{
            "task_id":"uuid-xxxx",
            "timestamp":"(保存时间戳)",
            "task_status":"FALLBACK_SUCCESS",//若只有部分任务步骤返回成功则为PARTIAL_SUCCESS
            "system_status":"READY",
            "call_chain":[
                {
                    "model_name":"model-x",
                    "capability":"image-generation",
                    "status"::"FAILED",
                    "error_code":xxx,
                    "attempted_at":"(保存时间戳)"
                },//若第一个任务步骤的大模型成功则为SCUCCESS，且不走下一步调用链
                {
                    "model_name":"model-y",
                    "capability":"image-generation",
                    "status"::"SUCCESS",
                    "attempted_at":"(保存时间戳)"
                },
                {
                    "model_name":"model-A",
                    "capability":"text-generation",
                    "status"::"FAILED",
                    "error_code":xxx,
                    "attempted_at":"(保存时间戳)"
                },//若第二个任务步骤的大模型成功则为SCUCCESS，不走下一步调用链
                {
                    "model_name":"model-B",
                    "capability":"text-generation",
                    "status"::"SUCCESS",
                    "attempted_at":"(保存时间戳)"
                }
            ], //模型降级路线
            "error_summary": [
                {"step": 1, "type": "PRIMARY_MODEL_FAILED"},
                {"step": 2, "type": "PRIMARY_MODEL_FAILED"}
            ]
        }
    }

    - 成功（final_status为PARTIAL_SUCCESS）：
        {
            "frontend_response":{
                "task_id": "uuid-xxxx",
                "task_status": "PARTIAL_SUCCESS",
                "system_status": "READY",
                "data": {
                        "results": [
                            {"type": "image", "url": "/data/outputs/img_001.png"},
                            {"type": "text", "content": "这是一张未来城市的图片..."}
                        ]
                    }
            },
            "log_record":{
                    "task_id":"uuid-xxxx",
                    "timestamp":"(保存时间戳)"
                    "task_status":"PARTIAL_SUCCESS",
                    "system_status":"READY",
                    "call_chain":[
                      {
                          "model_name":"model-x",
                          "capability":"image-generation",
                          "status"::"FAILED",
                          "error_code":xxx,
                          "attempted_at":"(保存时间戳)"
                      },//若第一个任务步骤的大模型成功则为SCUCCESS，则不走下一步调用链
                      {
                          "model_name":"model-y",
                          "capability":"image-generation",
                          "status"::"SUCCESS",
                          "attempted_at":"(保存时间戳)"
                      },
                      {
                          "model_name":"model-A",
                          "capability":"text-generation",
                          "status"::"FAILED",
                          "error_code":xxx,
                          "attempted_at":"(保存时间戳)"
                      },
                      {
                          "model_name":"model-B",
                          "capability":"text-generation",
                          "status"::"FAILED",
                          "error_code":xxx
                          "attempted_at":"(保存时间戳)"
                      }
                  ], //模型降级路线
                  "error_summary": [
                      {"step": 1, "type": "PRIMARY_MODEL_FAILED"},
                      {"step": 2, "type": "ALL_MODEL_FAILED"}
                  ]
            }
        }


    - 失败（final_status为FAILED）：
        {
                "frontend_response":{
                "task_id": "uuid-xxxx",
                "task_status": "FAILED",
                "system_status": "READY",
                "data": {
                    "type": "text",
